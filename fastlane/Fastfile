default_platform(:mac)

# Auth: prefer an App Store Connect API key (set ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_PATH).
def asc_api_key
  return nil unless ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"] && ENV["ASC_KEY_PATH"]
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_filepath: ENV["ASC_KEY_PATH"],
    in_house: false
  )
end

platform :mac do
  desc "Generate Xcode project from project.yml"
  lane :gen do
    sh("cd .. && DEVELOPMENT_TEAM=#{ENV['DEVELOPMENT_TEAM']} xcodegen generate")
  end

  desc "Archive + export a Mac App Store build"
  lane :build do
    gen
    build_mac_app(
      project: "Tray.xcodeproj",
      scheme: "Tray",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Tray"
    )
  end

  desc "Upload binary + metadata + screenshots to App Store Connect (does NOT submit for review)"
  lane :upload do
    key = asc_api_key
    deliver(
      api_key: key,
      pkg: "build/Tray.pkg",
      submit_for_review: false,
      automatic_release: false,
      force: true,                       # skip the HTML preview prompt
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end

  desc "Full pipeline: build → upload (review submission stays manual in App Store Connect)"
  lane :release do
    build
    upload
  end
end
